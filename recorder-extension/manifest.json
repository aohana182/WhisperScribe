{
    "manifest_version": 3,
    "name": "WhisperLiveKit Recorder",
    "version": "1.0",
    "description": "One-click meeting recorder. Captures tab + mic, transcribes locally, saves to C:\\MeetingTranscripts\\.",
    "icons": {
        "16":  "icons/icon16.png",
        "32":  "icons/icon32.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Record meeting with WhisperLiveKit"
    },
    "permissions": [
        "tabCapture",
        "activeTab",
        "storage",
        "nativeMessaging",
        "notifications"
    ],
    "web_accessible_resources": [
        {
            "resources": ["recorder.html", "recorder.js", "web/pcm_worklet.js"],
            "matches": ["<all_urls>"]
        }
    ]
}
